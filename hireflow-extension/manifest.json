{
  "manifest_version": 3,
  "name": "HireFlow Pro — Job Scraper",
  "version": "1.0.0",
  "description": "Save jobs directly from LinkedIn, Indeed, and Glassdoor to your HireFlow Pro tracker",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://www.indeed.com/*",
    "https://www.glassdoor.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Save to HireFlow Pro"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/jobs/*",
        "https://www.indeed.com/*",
        "https://www.glassdoor.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
